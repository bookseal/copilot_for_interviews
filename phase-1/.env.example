# Server
PORT=3000
NODE_ENV=development

# Mock mode - set to true to run without Azure credentials
MOCK_MODE=true

# Azure AI Speech Services (required if MOCK_MODE=false)
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus

# Audio Alert Thresholds
DB_MIN_THRESHOLD=-40   # Below this = too quiet (mumbling)
DB_MAX_THRESHOLD=-10   # Above this = too loud
WPM_MIN_THRESHOLD=100  # Below this = too slow
WPM_MAX_THRESHOLD=180  # Above this = too fast (rushing)
